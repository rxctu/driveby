includes:
    - vendor/larastan/larastan/extension.neon

parameters:
    paths:
        - app/
    level: 5
    ignoreErrors:
        # Stripe SDK has overly strict parameter types
        - '#Parameter \#1 \$params of static method Stripe\\PaymentIntent::create\(\)#'
        # Collection generic type variance issues with closures
        - '#contains unresolvable type#'
        # Eloquent relation properties resolved as Model instead of concrete type
        - '#Access to an undefined property Illuminate\\Database\\Eloquent\\Model::#'
        # Strict comparison with nullable stock field
        - '#Strict comparison using \!== between int and null will always evaluate to true#'
        # PHPDoc return type mismatch in FormRequest
        - '#PHPDoc tag @return with type .+ is incompatible with native type#'
        # Cannot call method on string (encrypted/cast attribute edge cases)
        - '#Cannot call method .+\(\) on string#'
        # Parameter type mismatch with relation->product (Model|null vs typed)
        - '#Parameter \#1 \$product of method .+ expects App\\Models\\Product, Illuminate\\Database\\Eloquent\\Model(\|null)? given#'
        # Collection sum/map closure type mismatch with generic Model
        - '#Parameter \#1 \$callback of method Illuminate\\Support\\Collection<.+>::sum\(\) expects#'
